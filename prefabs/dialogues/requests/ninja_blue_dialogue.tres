[resource]
script = ExtResource("2_script")
display_mode = 1
lines = Array[String](["Ночь делает шаги тише. В темноте легче услышать то, что днём скрывает шум.", "Синий ниндзя не спорит с ночью — он просто становится её частью.", "Когда мир темнеет, движения должны становиться точнее, а мысли — спокойнее.", "Лунный свет — лучший союзник для того, кто умеет исчезать между тенями."])
