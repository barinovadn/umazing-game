[resource]
script = ExtResource("2_script")
display_mode = 1
lines = Array[String](["Ты не видел моего кота? Он рыжий, наглый и делает вид, будто это я у него живу.", "Я уже весь двор обошёл. Если встретишь моего кота, скажи ему, что я всё равно не сержусь.", "Я сейчас ищу кота. Обычно он сидит там, где его искать совсем неудобно.", "Если заметишь рыжий хвост — сразу скажи мне. Это наверняка мой беглец.", "Помоги мне, пожалуйста. Без кота в доме как-то слишком тихо и подозрительно."])
portrait = ExtResource("1_portrait")
speaker_name = "Рыжий житель"
preset = "cat_wood"
wait_until_closed = false
