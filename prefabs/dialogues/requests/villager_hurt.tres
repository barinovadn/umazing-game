[gd_resource type="Resource" script_class="DialogueRequest" format=3]

[ext_resource type="Texture2D" path="res://prefabs/characters/villager_cat/portrait_surprised.png" id="1_portrait"]
[ext_resource type="Script" path="res://prefabs/dialogues/dialogue_request.gd" id="2_script"]

[resource]
script = ExtResource("2_script")
display_mode = 1
lines = Array[String](["Кот ранен? Только не это... Давай осторожно, ему сейчас страшнее, чем нам.", "Если он поранился, нужно отнести его домой и дать ему спокойно прийти в себя.", "Бедный мой комок шерсти... Надеюсь, это не серьёзно. Спасибо, что сказал мне сразу.", "Главное, не пугай его. Когда он ранен, он делает вид, что всё под контролем, но я-то знаю этот взгляд.", "Спасибо, что нашёл его вовремя. С раненым котом шутки плохи."])
portrait = ExtResource("1_portrait")
speaker_name = "Рыжий житель"
duration = -1.0
preset = "cat_wood"
block_movement = false
wait_until_closed = false
metadata/_custom_type_script = "res://prefabs/dialogues/dialogue_request.gd"
