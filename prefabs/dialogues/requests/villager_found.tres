[resource]
script = ExtResource("2_script")
display_mode = 1
lines = Array[String](["Ты нашёл его? Вот это новость! Я уже думал, что этот усатый герой снова победил всех нас.", "Спасибо! Теперь я наконец-то смогу перестать разговаривать с пустой миской.", "Нашёлся! Я знал, что он где-то рядом и просто притворяется легендой.", "Отлично! Передай коту, что я был очень строгим ровно пять секунд, а потом снова начал скучать.", "Спасибо тебе. Сегодня ты спас не только кота, но и мои нервы."])
portrait = ExtResource("1_portrait")
speaker_name = "Рыжий житель"
preset = "cat_wood"
