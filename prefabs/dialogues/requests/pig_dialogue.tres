[resource]
script = ExtResource("2_script")
display_mode = 1
lines = Array[String](["Хрю-хрю! В амбаре сегодня тепло, спокойно и пахнет свежим сеном.", "Если не шуметь, можно услышать, как сено шуршит лучше любой колыбельной.", "Я здесь главный эксперт по уюту. Амбар, сено и тишина — вот настоящее искусство жизни.", "Хрю! Не наступай на солому слишком громко, я тут как раз наслаждаюсь вечерним отдыхом."])
