[resource]
script = ExtResource("2_script")
display_mode = 1
lines = Array[String](["Что значит, мы снова его потеряли? Удивительно... и совершенно в его стиле.", "Он опять исчез? Похоже, мой кот считает себя мастером драматических выходов.", "Только обрадовался — и снова пусто. Этот пушистый артист точно делает это специально.", "Ладно, второй раунд. Я ищу кота, ты ищешь кота, а кот, скорее всего, ищет приключения.", "Похоже, он решил, что одного спасения ему было мало. Ну что ж, идём искать заново."])
portrait = ExtResource("1_portrait")
speaker_name = "Рыжий житель"
