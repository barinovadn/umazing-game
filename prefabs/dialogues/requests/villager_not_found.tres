[resource]
script = ExtResource("2_script")
display_mode = 1
lines = Array[String](["Значит, пока не нашли... Плохо. Он умеет прятаться так, будто готовился всю жизнь.", "Эх, снова пусто? Тогда будем искать дальше. Он не мог далеко уйти.", "Не нашли кота? Ладно, я ещё раз проверю дом, забор и все подозрительные кусты.", "Понятно... Тогда давай не сдаваться. Этот пушистый хитрец где-то рядом.", "Если его нигде нет, значит, он просто наблюдает за нами и наслаждается представлением."])
portrait = ExtResource("1_portrait")
speaker_name = "Рыжий житель"
preset = "cat_wood"
