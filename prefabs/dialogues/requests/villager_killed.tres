display_mode = 1
lines = Array[String](["Нет... только не говори, что с ним всё кончено. Я ведь просто хотел вернуть его домой.", "Я до последнего надеялся, что он опять выскочит из-за угла как ни в чём не бывало...", "Не знаю, что сказать. Без него дом теперь будет совсем другим.", "Спасибо, что не стал скрывать правду. Это больно, но лучше знать наверняка.", "Он был вредным, шумным и самым любимым существом в этом доме. Мне будет его не хватать."])
