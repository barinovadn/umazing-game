[sub_resource type="Resource" id="Resource_3kn5y"]
script = ExtResource("26_u63pd")
message = "Добро пожаловать, одинокий путник. Бамбуковый лес не знает парадных ворот — он сам решает, кого впустить."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="AtlasTexture" id="AtlasTexture_0bln5"]
atlas = ExtResource("20_it4qq")
region = Rect2(16, 32, 16, 16)

[sub_resource type="Resource" id="Resource_286v2"]
script = ExtResource("26_u63pd")
icon = SubResource("AtlasTexture_0bln5")
name = "Красивая Дубовая Табличка"
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_0bln5"]
script = ExtResource("26_u63pd")
message = "Хрупкий на вид, бамбук звенит под пальцами как натянутая тетива."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_kyf8x"]
script = ExtResource("26_u63pd")
message = "Сломай стебель — и тишина вздрогнет. Но поторопись: через несколько вдохов стена сомкнётся вновь."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="AtlasTexture" id="AtlasTexture_f0yi6"]
atlas = ExtResource("20_it4qq")
region = Rect2(0, 33, 16, 16)

[sub_resource type="Resource" id="Resource_vybwx"]
script = ExtResource("26_u63pd")
icon = SubResource("AtlasTexture_f0yi6")
name = "Предупреждающая Табличка"
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_f0yi6"]
script = ExtResource("26_u63pd")
message = "Я - ведро. Меня уронили, забыли, прокляли. Теперь я часть пейзажа."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="AtlasTexture" id="AtlasTexture_vybwx"]
atlas = ExtResource("20_it4qq")
region = Rect2(0, 33, 16, 16)

[sub_resource type="Resource" id="Resource_icmdr"]
script = ExtResource("26_u63pd")
icon = SubResource("AtlasTexture_vybwx")
name = "Дырявая Несчастная Табличка"
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_v5ujh"]
script = ExtResource("26_u63pd")
message = "Пред тобой - Хранитель Вод и Времени. Опусти взгляд. Задержи дыхание. Слушай тишину - в ней больше ответов, чем в словах."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="AtlasTexture" id="AtlasTexture_yvtkx"]
atlas = ExtResource("20_it4qq")
region = Rect2(16, 32, 16, 16)

[sub_resource type="Resource" id="Resource_fivxu"]
script = ExtResource("26_u63pd")
icon = SubResource("AtlasTexture_yvtkx")
name = "Замшелая Безмолвная Табличка"
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_efepq"]
script = ExtResource("26_u63pd")
message = "Вода смоет всё. Пар — лучший лекарь. Полотенце — лучший друг. Входи и очистись."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_x5fgb"]
script = ExtResource("26_u63pd")
message = "И не плескайся — духи бани этого не любят."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="AtlasTexture" id="AtlasTexture_wbpm7"]
atlas = ExtResource("20_it4qq")
region = Rect2(0, 33, 16, 16)

