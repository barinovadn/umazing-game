metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_8ox4s"]
script = ExtResource("26_u63pd")
message = "Сирануй не говорит. Не смотрит. Не судит."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

