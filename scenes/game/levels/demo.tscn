[sub_resource type="Resource" id="Resource_f2r25"]
script = ExtResource("22_5cmlo")
message = "О, живой! Слушай сюда. Моя кошка - лучшая кошка в мире. Она пропала. Твоя задача - найти. Бегом."
type_speed = 3
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_8r7lj"]
script = ExtResource("22_5cmlo")
message = "Ты выглядишь как человек, который умеет ползать под кустами. Мне нужен такой. Кошка пропала. Давай, работай."
type_speed = 3
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_o8fgc"]
script = ExtResource("22_5cmlo")
message = "Ты мне нравишься. У тебя лицо человека, которому всё равно, куда идти. Иди ищи Мурку. Она рыжая. Или серая. Короче, кошка."
type_speed = 3
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_ffajp"]
script = ExtResource("22_5cmlo")
message = "О, ты! Да, ты! Слушай сюда. Если ты найдёшь мою кошку быстрее, чем за час - я разрешу тебе гордиться собой целых пять секунд."
type_speed = 3
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

