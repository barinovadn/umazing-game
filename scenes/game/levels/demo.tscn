metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_6wp27"]
script = ExtResource("22_5cmlo")
message = "Двигаться можно на клавиши WASD,
А также зажав правую кнопку мыши!"
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_55rf0"]
script = ExtResource("22_5cmlo")
message = ". . . "
punctuation_significance = 2.0
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_q2oqs"]
script = ExtResource("22_5cmlo")
name = "Бесполезная Дубовая Табличка"
message = "Но, кажется, вы и без меня все это знали..."
type_speed = 3
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="AtlasTexture" id="AtlasTexture_hlq0y"]
atlas = ExtResource("31_ctk38")
region = Rect2(144, 176, 16, 16)

[sub_resource type="Resource" id="Resource_dq4oe"]
script = ExtResource("22_5cmlo")
icon = SubResource("AtlasTexture_hlq0y")
name = "Дружелюбная Дубовая Табличка"
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_aokcs"]
script = ExtResource("22_5cmlo")
message = "Пункт № 1.
Не все объекты, с которыми можно взаимодействовать, отмечены маркерами. Как, например, этот."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_6s036"]
script = ExtResource("22_5cmlo")
message = "Пункт № 2.
Диалоги можно пропускать на клавишу \"E\" или \"Пробел\"."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_fvuxf"]
script = ExtResource("22_5cmlo")
message = "Пункт № 3.
Зажав левую кнопку мыши - персоонаж всгеда будет повернут в сторону курсора, даже при ходьбе. Эту особенность можно применять для стрельбы."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_ib0lp"]
script = ExtResource("22_5cmlo")
message = "Пункт ЭКСТРА.
Кажется другая табличка забыла сказать вам..
Для открытия инвентаря - нажмите \"I\".
Чтобы атаковать - зажмите \"Пробел\"."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

