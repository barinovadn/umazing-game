metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_bu17f"]
script = ExtResource("8_gx8e6")
message = "Он улыбается. Кажется, тишина после ухода людей ему даже нравится"
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_gx8e6"]
script = ExtResource("8_gx8e6")
message = "Статуя покрылась трещинами, из которых пробивается молодая трава"
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="AtlasTexture" id="AtlasTexture_r2ha7"]
