[sub_resource type="Resource" id="Resource_j4lfh"]
script = ExtResource("8_gx8e6")
message = "Тот, кто ищет силы ради мести, становится рабом своей ненависти..."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_6gtln"]
script = ExtResource("8_gx8e6")
message = "...Тот, кто ищет силы ради защиты других, становится воином..."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_mw6v1"]
script = ExtResource("8_gx8e6")
message = "...Помни об этом на своём пути."
