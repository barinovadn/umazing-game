[sub_resource type="Resource" id="Resource_r2ha7"]
script = ExtResource("8_gx8e6")
message = "Мох укутал его плечи теплее, чем любая ряса."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

[sub_resource type="Resource" id="Resource_7y70h"]
script = ExtResource("8_gx8e6")
message = "Время стерло черты его лица, но не его покой."
metadata/_custom_type_script = "uid://3n0f04b0rgoe"

